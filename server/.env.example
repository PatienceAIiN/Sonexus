# Database
DATABASE_URL=postgresql+asyncpg://sonex:sonex@localhost:5432/sonex

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_MINUTES=1440

# Storage: failover (Cloudinary -> R2) or local (dev)
STORAGE_BACKEND=failover
LOCAL_STORAGE_DIR=./data/objects
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=sonex

# Rate limiting
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW=60

MIN_APP_VERSION=1
